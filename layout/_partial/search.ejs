<%
// The post index lives in a standalone JSON file emitted by
// scripts/search-index.js; main.js fetches it lazily when the panel opens.
%>
<div class="search-panel" aria-hidden="true" data-index-url="<%= url_for('flatpaper-search.json') %>">
  <div class="search-backdrop js-search-close"></div>
  <section class="search-dialog" role="dialog" aria-modal="true" aria-label="搜索文章">
    <span class="tape tape--top-left" aria-hidden="true"></span>
    <header class="search-head">
      <h2><span class="green-dot"></span>搜索文章</h2>
      <button class="icon-button js-search-close" type="button" aria-label="关闭搜索">
        <%- partial('_partial/icons', { icon: 'x' }) %>
      </button>
    </header>
    <label class="search-field">
      <%- partial('_partial/icons', { icon: 'search' }) %>
      <input id="flatpaper-search" class="search-input" type="search" placeholder="输入关键词，按 Esc 关闭" autocomplete="off">
    </label>
    <div class="search-results" data-empty="输入关键词后显示匹配的文章">
      <p class="search-empty">输入关键词后显示匹配的文章</p>
    </div>
  </section>
</div>

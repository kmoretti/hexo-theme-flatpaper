<div class="search-panel" aria-hidden="true">
  <div class="search-backdrop js-search-close"></div>
  <section class="search-dialog" role="dialog" aria-modal="true" aria-label="搜索文章">
    <span class="tape tape--top-left" aria-hidden="true"></span>
    <header class="search-head">
      <h2><span class="green-dot"></span>搜索文章</h2>
      <button class="icon-button js-search-close" type="button" aria-label="关闭搜索">
        <%- partial('_partial/icons', { icon: 'x' }) %>
      </button>
    </header>
    <label class="search-field">
      <%- partial('_partial/icons', { icon: 'search' }) %>
      <input id="flatpaper-search" class="search-input" type="search" placeholder="输入关键词，按 Esc 关闭" autocomplete="off">
    </label>
    <div class="search-results" data-empty="输入关键词后显示匹配的文章">
      <p class="search-empty">输入关键词后显示匹配的文章</p>
    </div>
  </section>
</div>
<%
var searchLimit = (theme.search && typeof theme.search.limit === 'number') ? theme.search.limit : 0;
var searchPool = flatpaper_sorted_posts();
if (searchLimit > 0) searchPool = searchPool.slice(0, searchLimit);
%>
<script type="application/json" id="flatpaper-post-index">
[
<% searchPool.forEach(function (post, index, arr) { %>
  {
    "title": <%- JSON.stringify(post.title || 'Untitled') %>,
    "url": <%- JSON.stringify(url_for(post.path)) %>,
    "date": <%- JSON.stringify(date(post.date, 'YYYY-MM-DD')) %>,
    "text": <%- JSON.stringify(strip_html(post.excerpt || post.content || '').replace(/\s+/g, ' ').trim().slice(0, 200)) %>
  }<%= index < arr.length - 1 ? ',' : '' %>
<% }) %>
]
</script>

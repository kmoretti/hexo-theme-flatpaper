<%
var f = theme.footer || {};
var year = new Date().getFullYear();
var name = (theme.profile && theme.profile.name) ? theme.profile.name : (config.author || 'FlatPaper');
function fill(tpl, fallback) {
  var s = (tpl == null) ? fallback : String(tpl);
  return s.replace(/\{year\}/g, year).replace(/\{name\}/g, name);
}
var left = fill(f.left, '© ' + year + ' ' + (config.title || 'FlatPaper') + '. All rights reserved.');
var right = fill(f.right, 'Made with care by ' + name);
%>
<footer class="site-footer">
  <span class="site-footer__left"><%- left %></span>
  <span class="site-footer__right"><%- right %></span>
</footer>

<%
var recentPosts = flatpaper_sorted_posts()
  .filter(function (p) { return !page.path || p.path !== page.path; })
  .slice(0, theme.recent_posts || 5);
%>
<% if (recentPosts.length) { %>
  <section class="side-card recent-card">
    <h2><%- partial('_partial/icons', { icon: 'clock' }) %>最近文章</h2>
    <ul class="recent-list">
      <% recentPosts.forEach(function (post) { %>
        <li>
          <a class="recent-item" href="<%- url_for(post.path) %>">
            <strong><%= post.title %></strong>
            <em><%= date(post.date, 'YYYY-MM-DD') %></em>
          </a>
        </li>
      <% }) %>
    </ul>
  </section>
<% } %>

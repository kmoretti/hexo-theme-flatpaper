<%
// Twikoo comments. Renders on content pages — posts and standalone pages
// (about / friends / etc.) — never on index pages (home / archive / category /
// tag), where the visible content is a list of posts and a comment box has no
// clear subject. Four gates: theme.twikoo.enable, theme.twikoo.envId, the
// page being a post or `page` layout, and `page.comments !== false` (any page
// can still opt out via front-matter).
// The Twikoo SDK <script> is loaded once globally by _partial/twikoo-sdk.ejs;
// this partial only emits the DOM mount point and the init call.
var tk = theme.twikoo || {};
var isContentPage = is_post() || page.layout === 'page';
var enabled = tk.enable && tk.envId && isContentPage && page.comments !== false;
if (enabled) {
%>
<section class="comments-section" aria-label="评论">
  <header class="comments-section__head">
    <h2><%- partial('_partial/icons', { icon: 'message-circle' }) %>评论</h2>
  </header>
  <div id="tcomment"></div>
</section>
<script>
window.addEventListener('load', function () {
  if (typeof twikoo === 'undefined') return;
  twikoo.init({
    envId: <%- JSON.stringify(tk.envId) %>,
    el: '#tcomment'
  });
});
</script>
<% } %>

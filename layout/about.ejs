<%
  var aboutPage = page;

  // 博主信息
  var authorName = config.author || '博主';
  var authorRole = theme.about && theme.about.author && theme.about.author.role || theme.profile && theme.profile.role || '一个普通的创作者';
  var authorBio = theme.about && theme.about.author && theme.about.author.bio || theme.profile && theme.profile.bio || '人生如逆旅，我亦是行人。';
  var authorLocation = theme.about && theme.about.author && theme.about.author.location || '中国';
  var authorMotto = theme.about && theme.about.author && theme.about.author.motto || '保持热爱，奔赴山海';
  var authorAvatar = theme.profile && theme.profile.avatar || '';
  var avatarShape = theme.profile && theme.profile.avatar_shape || 'square';
  var personalityType = theme.about && theme.about.personality && theme.about.personality.type || 'INFJ-A';
  var personalityName = theme.about && theme.about.personality && theme.about.personality.name || '提倡者';

  // 性格类型 -> 图片 & URL 映射（参考 16personalities.com）
  var personalityMap = {
    INTJ: { image: 'intj-architect', slug: 'intj' },
    INTP: { image: 'intp-logician', slug: 'intp' },
    ENTJ: { image: 'entj-commander', slug: 'entj' },
    ENTP: { image: 'entp-debater', slug: 'entp' },
    INFJ: { image: 'infj-advocate', slug: 'infj' },
    INFP: { image: 'infp-mediator', slug: 'infp' },
    ENFJ: { image: 'enfj-protagonist', slug: 'enfj' },
    ENFP: { image: 'enfp-campaigner', slug: 'enfp' },
    ISTJ: { image: 'istj-logistician', slug: 'istj' },
    ISFJ: { image: 'isfj-defender', slug: 'isfj' },
    ESTJ: { image: 'estj-executive', slug: 'estj' },
    ESFJ: { image: 'esfj-consul', slug: 'esfj' },
    ISTP: { image: 'istp-virtuoso', slug: 'istp' },
    ISFP: { image: 'isfp-adventurer', slug: 'isfp' },
    ESTP: { image: 'estp-entrepreneur', slug: 'estp' },
    ESFP: { image: 'esfp-entertainer', slug: 'esfp' }
  };
  var personalityBase = personalityType.substring(0, 4).toUpperCase();
  var pMap = personalityMap[personalityBase] || personalityMap['INFJ'];
  var personalityImage = 'https://www.16personalities.com/static/images/personality-types/avatars/' + pMap.image + '.png';
  var personalityUrl = theme.about && theme.about.personality && theme.about.personality.url || 'https://www.16personalities.com/ch/' + pMap.slug + '-人格';
  var personalityColor = { INTJ: '#885fb8', INTP: '#885fb8', ENTJ: '#885fb8', ENTP: '#885fb8', INFJ: '#56a178', INFP: '#56a178', ENFJ: '#56a178', ENFP: '#56a178', ISTJ: '#4298b4', ISFJ: '#4298b4', ESTJ: '#4298b4', ESFJ: '#4298b4', ISTP: '#e4ae3a', ISFP: '#e4ae3a', ESTP: '#e4ae3a', ESFP: '#e4ae3a' };
  var personalityColorHex = personalityColor[personalityBase] || '#56a178';

  var profileItems = (theme.about && theme.about.profile) || [
    { label: '姓名', value: authorName, color: '#43a6c6' },
    { label: '生于', value: '2000', color: '#c69043' },
    { label: '故乡', value: authorLocation, color: '#d44040' },
    { label: '职业', value: authorRole, color: '#b04fe6' },
    { label: '兴趣', value: '编程与创作', color: '#43c66f' },
    { label: '梦想', value: '创造价值', color: '#c643b3' }
  ];
  var mottoMain = theme.about && theme.about.motto && theme.about.motto.main || [authorMotto];
  var mottoSub = theme.about && theme.about.motto && theme.about.motto.sub || '';

  // 社交 & 创作
  var socialLinks = theme.profile && theme.profile.social || {};
  var creationLinks = theme.about && theme.about.creation || [];

  // 本站信息
  var established = (theme.about && theme.about.runtime && theme.about.runtime.established) || theme.blog && theme.blog.established || '2024-01-01';
  var versions = (theme.about && theme.about.versions) || [
    { name: 'FlatPaper', version: 'latest' }
  ];

  // 访问统计
  var unionLinks = (theme.about && theme.about.union) || [];

  // 心路历程
  var storyContent = theme.about && theme.about.story && theme.about.story.content || '';

  // 站点统计
  var postCount = site.posts.length;
  var categoryCount = site.categories.length;
  var tagCount = site.tags.length;
%>

<div id="about-page">

  <!-- 个人介绍 Hero -->
  <section class="about-hero">
    <div class="about-hero__left">
      <h1 class="about-hero__greeting">你好！</h1>
      <div class="about-hero__name">我是 <span class="accent-text"><%= authorName %></span></div>
      <div class="about-hero__bio"><%= authorBio %></div>
      <div class="about-hero__role"><%= authorRole %></div>
      <div class="about-hero__buttons">
        <a href="#about-author" class="about-btn">博主信息</a>
        <a href="#about-site" class="about-btn">本站信息</a>
      </div>
    </div>
    <div class="about-hero__right">
      <% if (authorAvatar) { %>
        <img src="<%- authorAvatar %>" alt="<%= authorName %>" class="about-hero__photo<%= avatarShape === 'circle' ? ' about-hero__photo--circle' : '' %>" loading="lazy" />
      <% } else { %>
        <div class="about-hero__photo about-hero__photo--default">
          <span><%= authorName[0] %></span>
        </div>
      <% } %>
    </div>
  </section>

  <!-- 博主信息 Section 01 -->
  <section id="about-author" class="about-section" scroll-margin-top="100px">
    <div class="about-section__header">
      <span class="about-section__number">01</span>
      <h2 class="about-section__title">博主信息</h2>
      <div class="about-section__subtitle"><%= authorName %></div>
    </div>

    <div class="about-grid about-grid--two">
      <!-- 个人信息 -->
      <div class="about-paper">
        <div class="about-paper__tape"></div>
        <div class="about-paper__inner">
          <% for (var i = 0; i < profileItems.length; i += 3) { %>
            <div class="about-profile-row">
              <% for (var j = i; j < Math.min(i + 3, profileItems.length); j++) { %>
                <div class="about-profile-item">
                  <span class="about-profile-label"><%= profileItems[j].label %></span>
                  <span class="about-profile-value" style="color:<%= profileItems[j].color || 'var(--ink)' %>"><%= profileItems[j].value %></span>
                </div>
              <% } %>
            </div>
          <% } %>
        </div>
      </div>

      <!-- 性格 -->
      <div class="about-paper">
        <div class="about-paper__tape about-paper__tape--pink"></div>
        <div class="about-paper__inner about-paper__inner--personality">
          <span class="about-paper__label">性格</span>
          <div class="about-personality">
            <div class="about-personality__name"><%= personalityName %></div>
            <div class="about-personality__type" style="color:<%= personalityColorHex %>"><%= personalityType %></div>
            <img class="about-personality__image" src="<%- personalityImage %>" alt="<%= personalityName %>" loading="lazy" />
            <div class="about-personality__link">
              在 <a href="https://www.16personalities.com/ch" target="_blank" rel="noopener">16Personalities</a>
              了解关于 <a href="<%- personalityUrl %>" target="_blank" rel="noopener"><%= personalityName %></a> 的更多信息
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="about-grid about-grid--two">
      <!-- 座右铭 -->
      <div class="about-paper">
        <div class="about-paper__tape about-paper__tape--green"></div>
        <div class="about-paper__inner">
          <span class="about-paper__label">座右铭</span>
          <div class="about-motto">
            <% mottoMain.forEach(function(line, idx) { %>
              <div class="about-motto__line<%= idx < mottoMain.length - 1 ? ' about-motto__line--faded' : '' %>"><%= line %></div>
            <% }); %>
            <% if (mottoSub) { %>
              <div class="about-motto__sub"><%= mottoSub %></div>
            <% } %>
          </div>
        </div>
      </div>

      <!-- 联系方式 -->
      <div class="about-paper">
        <div class="about-paper__tape about-paper__tape--yellow"></div>
        <div class="about-paper__inner">
          <span class="about-paper__label">账号</span>
          <div class="about-paper__heading">联系方式</div>
          <div class="about-link-list">
            <% var socialEntries = Object.entries(socialLinks); %>
            <% socialEntries.forEach(function(entry) { %>
              <%
                var name = entry[0];
                var val = entry[1];
                var url = typeof val === 'object' ? val.url : val;
                var tooltip = typeof val === 'object' && val.tooltip ? val.tooltip : name;
              %>
              <a href="<%- url %>" class="about-link-btn<%= url && url.indexOf('mailto:') === 0 ? '' : ' about-link-btn--external' %>"<%= url && url.indexOf('mailto:') === -1 ? ' target="_blank" rel="noopener"' : '' %>><%= name %></a>
            <% }); %>
          </div>
        </div>
      </div>
    </div>

    <!-- 创作平台 -->
    <div class="about-paper about-paper--full">
      <div class="about-paper__tape about-paper__tape--blue"></div>
      <div class="about-paper__inner">
        <span class="about-paper__label">订阅</span>
        <div class="about-paper__heading">创作平台</div>
        <% if (creationLinks.length > 0) { %>
        <div class="about-link-list">
          <% creationLinks.forEach(function(item) { %>
            <a href="<%- item.url %>" class="about-link-btn about-link-btn--external" target="_blank" rel="noopener"><%= item.name %></a>
          <% }); %>
        </div>
        <% } else { %>
        <p class="about-empty-hint">暂未加入平台</p>
        <% } %>
      </div>
    </div>
  </section>

  <!-- 本站信息 Section 02 -->
  <section id="about-site" class="about-section">
    <div class="about-section__header">
      <span class="about-section__number">02</span>
      <h2 class="about-section__title">本站信息</h2>
      <div class="about-section__run" id="about-runtime">已稳定运行 <span id="about-runtime-days">--</span> 天 🚀</div>
    </div>

    <div class="about-grid about-grid--two">
      <!-- 版本 -->
      <div class="about-paper">
        <div class="about-paper__tape about-paper__tape--green"></div>
        <div class="about-paper__inner about-paper__inner--center">
          <div class="about-versions">
            <% versions.forEach(function(v) { %>
              <div class="about-version">
                <span class="about-version__name"><%= v.name %></span>
                <span class="about-version__ver">V<%= v.version %></span>
              </div>
            <% }); %>
          </div>
        </div>
      </div>

      <!-- 站点统计 -->
      <div class="about-paper">
        <div class="about-paper__tape about-paper__tape--pink"></div>
        <div class="about-paper__inner">
          <div class="about-site-stats">
            <span><strong id="about-post-count"><%= postCount %></strong>篇文章</span>
            <span><strong id="about-cat-count"><%= categoryCount %></strong>个分类</span>
            <span><strong id="about-tag-count"><%= tagCount %></strong>个标签</span>
          </div>
        </div>
      </div>
    </div>

    <!-- 站长联盟 -->
    <div class="about-paper about-paper--full">
      <div class="about-paper__tape"></div>
      <div class="about-paper__inner">
        <span class="about-paper__label">共创</span>
        <div class="about-paper__heading">站长联盟</div>
        <% if (unionLinks.length > 0) { %>
        <div class="about-link-list">
          <% unionLinks.forEach(function(item) { %>
            <a href="<%- item.url %>" class="about-link-btn about-link-btn--external" target="_blank" rel="noopener"><%= item.name %></a>
          <% }); %>
        </div>
        <% } else { %>
        <p class="about-empty-hint">未加入站长联盟</p>
        <% } %>
      </div>
    </div>
  </section>

  <!-- 心路历程 -->
  <% if (storyContent) { %>
  <section class="about-section about-section--story">
    <div class="about-paper about-paper--full about-paper--warm">
      <div class="about-paper__inner">
        <span class="about-paper__label">心路历程</span>
        <div class="about-paper__heading">关于本站的介绍</div>
        <div class="about-story">
          <%- markdown(storyContent) %>
        </div>
      </div>
    </div>
  </section>
  <% } %>

  <!-- 页面正文（如果 Markdown 有额外内容） -->
  <% if (page.content && page.content.trim()) { %>
  <div class="about-extra-content">
    <%- page.content %>
  </div>
  <% } %>

</div>

<script>
(function() {
  // 运行时间
  var established = '<%- established %>';
  var startMs = new Date(established).getTime();
  var nowMs = Date.now();
  var days = Math.floor((nowMs - startMs) / 86400000);
  var daysEl = document.getElementById('about-runtime-days');
  if (daysEl) daysEl.textContent = days;
})();
</script>

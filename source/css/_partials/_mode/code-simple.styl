/* ============== CODE BLOCK - SIMPLE THEME ============== */
body[data-code-theme="simple"] .article-content .highlight,
body[data-code-theme="simple"] .article-content > pre {
  background: var(--paper-warm) !important;
  color: var(--ink);
  border: 2px solid var(--ink) !important;
  border-radius: 0 !important;
  box-shadow: none !important;
}

body[data-code-theme="simple"] .article-content .highlight::before,
body[data-code-theme="simple"] .article-content .highlight::after {
  /* Hide the macOS traffic lights */
  display: none !important;
}

body[data-code-theme="simple"] .article-content .highlight .code-bar {
  left: 0;
  right: 0;
  padding: 0 16px;
  height: 38px;
  border-bottom: 2px solid var(--ink);
}

body[data-code-theme="simple"] .article-content .highlight .code-lang {
  background: transparent !important;
  color: var(--ink) !important;
  font-weight: 700;
  font-size: 13px;
  text-transform: uppercase;
  padding: 0;
  margin-right: auto;
}

body[data-code-theme="simple"] .article-content .highlight .code-action {
  color: var(--ink-soft);
  background: transparent !important;
  border: none !important;
  border-radius: 0 !important;
}

body[data-code-theme="simple"] .article-content .highlight .code-action:hover {
  color: var(--ink);
  transform: none !important;
}

body[data-code-theme="simple"] .article-content .highlight .code-copy.is-copied {
  color: var(--color-accent);
}

body[data-code-theme="simple"] .article-content .highlight td.gutter {
  background: transparent;
  border-right: 1px dashed var(--dash);
}

body[data-code-theme="simple"] .article-content .highlight td.gutter pre {
  color: var(--muted);
}

/* Syntax highlighting mapped to theme variables: without these overrides the
   unscoped code-dark.styl token colors would apply, which are unreadable on
   the simple theme's light background. */
body[data-code-theme="simple"] .article-content .highlight .comment,
body[data-code-theme="simple"] .article-content .highlight .quote { color: var(--muted); font-style: italic; }

body[data-code-theme="simple"] .article-content .highlight .keyword,
body[data-code-theme="simple"] .article-content .highlight .selector-tag,
body[data-code-theme="simple"] .article-content .highlight .literal,
body[data-code-theme="simple"] .article-content .highlight .built_in { color: var(--color-accent); font-weight: 600; }

body[data-code-theme="simple"] .article-content .highlight .string,
body[data-code-theme="simple"] .article-content .highlight .regexp,
body[data-code-theme="simple"] .article-content .highlight .meta-string { color: var(--color-accent); }

body[data-code-theme="simple"] .article-content .highlight .number,
body[data-code-theme="simple"] .article-content .highlight .symbol,
body[data-code-theme="simple"] .article-content .highlight .bullet { color: var(--orange); }

body[data-code-theme="simple"] .article-content .highlight .title,
body[data-code-theme="simple"] .article-content .highlight .name,
body[data-code-theme="simple"] .article-content .highlight .selector-id,
body[data-code-theme="simple"] .article-content .highlight .selector-class { color: var(--blue); font-weight: 600; }

body[data-code-theme="simple"] .article-content .highlight .attr,
body[data-code-theme="simple"] .article-content .highlight .variable,
body[data-code-theme="simple"] .article-content .highlight .template-variable { color: var(--orange); }

body[data-code-theme="simple"] .article-content .highlight .params { color: var(--ink); }

body[data-code-theme="simple"] .article-content .highlight .tag,
body[data-code-theme="simple"] .article-content .highlight .doctag { color: var(--color-accent); }

body[data-code-theme="simple"] .article-content .highlight .property,
body[data-code-theme="simple"] .article-content .highlight .attribute { color: var(--blue); }

body[data-code-theme="simple"] .article-content .highlight .type,
body[data-code-theme="simple"] .article-content .highlight .class { color: var(--orange); font-weight: 600; }

body[data-code-theme="simple"] .article-content .highlight .deletion { color: #cf222e; background: rgba(255,0,0,0.1); }
body[data-code-theme="simple"] .article-content .highlight .addition { color: var(--color-accent); background: rgba(0,255,0,0.1); }

/* Scrollbar styling for simple theme */
body[data-code-theme="simple"] .article-content .highlight td.code pre::-webkit-scrollbar-thumb,
body[data-code-theme="simple"] .article-content > pre::-webkit-scrollbar-thumb {
  background: var(--dash);
  border-radius: 0;
}

.memos-ticker {
  position: relative;
  display: flex;
  align-items: center;
  gap: 14px;
  margin: 0 0 28px;
  padding: 14px 20px;
  border: 1px dashed var(--dash);
  border-radius: 5px 12px 7px 10px;
  background: var(--paper);
  box-shadow: 5px 6px 0 var(--shadow-soft), inset 0 0 24px rgba(125, 92, 48, 0.06);
  transform: rotate(-0.25deg);
  touch-action: pan-y;
}

.memos-ticker::before,
.memos-ticker::after {
  position: absolute;
  content: '';
  pointer-events: none;
}

.memos-ticker::before {
  inset: 7px;
  border: 1px solid rgba(125, 92, 48, 0.08);
  border-radius: 3px 8px 5px 7px;
}

.memos-ticker::after {
  right: 0;
  bottom: 0;
  width: 110px;
  height: 22px;
  background: repeating-linear-gradient(-45deg, transparent 0 7px, rgba(115, 88, 53, 0.08) 7px 9px);
}

.memos-ticker__tape {
  position: absolute;
  top: -9px;
  left: 48%;
  z-index: 2;
  width: 88px;
  height: 24px;
  background: rgba(219, 183, 118, 0.62);
  box-shadow: 0 2px 4px rgba(73, 51, 27, 0.12);
  transform: rotate(2deg);
}

.memos-ticker__label {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 8px;
  flex-shrink: 0;
  text-decoration: none;
  color: inherit;
}

.memos-ticker__label h2 {
  margin: 0;
  color: var(--ink);
  font-family: var(--font-display);
  font-size: 0.95rem;
  font-weight: 700;
  letter-spacing: 0.03em;
  white-space: nowrap;
}

.memos-ticker__label:hover .memos-ticker__pin {
  transform: scale(1.15);
  transition: transform 0.2s ease;
}

.memos-ticker__pin {
  width: 11px;
  height: 11px;
  border-radius: 50%;
  background: var(--accent);
  box-shadow: 0 1px 0 rgba(0, 0, 0, 0.18), inset 0 1px 2px rgba(255, 255, 255, 0.45);
}

.memos-ticker__date {
  color: var(--muted);
  font-family: var(--font-mono);
  font-size: 0.68rem;
  letter-spacing: 0.04em;
  white-space: nowrap;
  flex-shrink: 0;
}

.memos-ticker__viewport {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  background-image: linear-gradient(transparent 80%, rgba(213, 174, 104, 0.22) 80%);
  background-size: 100% 1.65em;
}

.memos-ticker__message {
  margin: 0;
  overflow: hidden;
  color: var(--ink-soft);
  font-family: var(--font-body);
  font-size: 0.92rem;
  line-height: 1.6;
  text-overflow: ellipsis;
  white-space: nowrap;
  transition: opacity 0.35s ease, transform 0.35s ease;
}

.memos-ticker__message.is-loading,
.memos-ticker__message.is-error {
  color: var(--muted);
  white-space: normal;
}

.memos-ticker__message a {
  color: var(--accent);
  text-decoration: underline;
  text-decoration-style: dashed;
  text-underline-offset: 2px;
}

.memos-ticker__message a:hover {
  color: var(--color-accent-strong);
}

.memos-ticker__message code {
  padding: 0 4px;
  border: 1px dashed var(--dash);
  border-radius: 4px;
  background: var(--color-accent-soft);
  font-family: var(--font-mono);
  font-size: 0.88em;
  color: var(--ink);
}

.memos-ticker__message .memos-img {
  color: var(--muted);
  font-style: italic;
}

.memos-ticker__controls {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 6px;
  flex-shrink: 0;
  color: var(--muted);
  font-family: var(--font-mono);
  font-size: 0.68rem;
  white-space: nowrap;
}

.memos-ticker__controls button {
  display: inline-grid;
  width: 24px;
  height: 24px;
  place-items: center;
  padding: 0;
  border: 1px solid var(--dash);
  border-radius: 50%;
  background: transparent;
  color: var(--ink-soft);
  cursor: pointer;
  transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
}

.memos-ticker__controls button:hover,
.memos-ticker__controls button:focus-visible {
  background: var(--accent);
  color: var(--paper);
  transform: translateY(-1px);
}

/* Progress bar */
.memos-ticker__progress {
  position: absolute;
  left: 0;
  bottom: 0;
  z-index: 3;
  height: 3px;
  width: 0%;
  background: linear-gradient(90deg, var(--accent), var(--yellow));
  border-radius: 0 2px 0 0;
  transition: width 0.3s linear;
  pointer-events: none;
}

.memos-ticker.is-paused .memos-ticker__progress {
  transition: none;
}

/* Transition states */
.memos-ticker.is-changing .memos-ticker__message {
  opacity: 0;
  transform: translateY(6px);
}

.memos-ticker.is-ready .memos-ticker__message {
  opacity: 1;
  transform: translateY(0);
}

/* Dark mode */
.dark-mode .memos-ticker {
  box-shadow: 5px 6px 0 var(--shadow-soft), inset 0 0 24px rgba(255, 255, 255, 0.025);
}

/* ============ Mobile (<= 600px) ============ */
@media (max-width: 600px) {
  .memos-ticker {
    flex-wrap: wrap;
    gap: 0;
    margin-bottom: 20px;
    padding: 0;
    border-radius: 4px 8px 5px 7px;
    transform: none;
  }

  .memos-ticker::before,
  .memos-ticker::after {
    display: none;
  }

  .memos-ticker__tape {
    top: -6px;
    left: 50%;
    width: 64px;
    height: 18px;
    transform: translateX(-50%) rotate(1.5deg);
  }

  /* Top row: label + date */
  .memos-ticker__label {
    width: 100%;
    padding: 12px 14px 6px;
    gap: 7px;
    justify-content: flex-start;
  }

  .memos-ticker__label h2 {
    font-size: 0.88rem;
  }

  .memos-ticker__pin {
    width: 9px;
    height: 9px;
  }

  .memos-ticker__date {
    margin-left: auto;
  }

  /* Middle: content */
  .memos-ticker__viewport {
    width: 100%;
    min-height: 20px;
    padding: 2px 14px 6px;
    background-image: none;
  }

  .memos-ticker__message {
    font-size: 0.82rem;
    line-height: 1.55;
    white-space: normal;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Bottom: controls */
  .memos-ticker__controls {
    width: 100%;
    justify-content: center;
    gap: 14px;
    padding: 4px 14px 12px;
    font-size: 0.66rem;
  }

  .memos-ticker__controls button {
    width: 28px;
    height: 28px;
  }

  .memos-ticker__progress {
    height: 2px;
  }
}

/* ============ Very small (<= 380px) ============ */
@media (max-width: 380px) {
  .memos-ticker__label {
    padding: 10px 10px 5px;
  }

  .memos-ticker__label h2 {
    font-size: 0.82rem;
  }

  .memos-ticker__viewport {
    padding: 2px 10px 5px;
  }

  .memos-ticker__controls {
    padding: 3px 10px 10px;
  }
}

/* ============ Touch hover hint ============ */
@media (hover: none) and (pointer: coarse) {
  .memos-ticker__controls button:active {
    background: var(--accent);
    color: var(--paper);
    transform: scale(0.92);
  }
}

/* ============ Reduced motion ============ */
@media (prefers-reduced-motion: reduce) {
  .memos-ticker__message {
    transition: none;
  }

  .memos-ticker__progress {
    transition: none;
  }
}

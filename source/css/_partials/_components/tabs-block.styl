/* ============== TABS BLOCK ============== */
.flatpaper-tabs {
  position: relative;
  margin: 32px 0;
  z-index: 1;
  background: var(--paper);
  border: 2px dashed var(--dash);
  border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
  box-shadow: var(--soft-shadow);
}

/* Tape on the top right */
.flatpaper-tabs::after {
  content: "";
  position: absolute;
  top: -12px;
  right: 30px;
  z-index: 2;
  width: 70px;
  height: 20px;
  background-color: var(--tape-green);
  background-image: var(--tape-stripes);
  transform: rotate(5deg);
}

.flatpaper-tabs__intro {
  padding: 12px 16px;
  border-bottom: 1px dashed var(--line);
  color: var(--ink-soft);
  font-size: 13px;
  line-height: 1.7;
}

.flatpaper-tabs__intro > :first-child { margin-top: 0; }
.flatpaper-tabs__intro > :last-child { margin-bottom: 0; }

.flatpaper-tabs__nav {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  padding: 8px 14px 8px;
  background: transparent;
  border-bottom: 2px dashed var(--dash);
}

.flatpaper-tabs__nav-item {
  appearance: none;
  position: relative;
  display: inline-flex;
  align-items: center;
  padding: 8px 14px;
  margin: 0 2px;
  border: 0;
  border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
  color: var(--muted);
  font: inherit;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.2px;
  background: transparent;
  cursor: pointer;
  transition: background-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
}

.flatpaper-tabs__nav-item:hover:not(.is-active) {
  color: var(--ink);
  background-color: unquote('color-mix(in srgb, var(--dash) 30%, transparent)');
}

.flatpaper-tabs__nav-item.is-active {
  color: var(--color-accent-strong);
  background-color: var(--color-accent-soft);
  background-image: var(--nav-tape-stripes);
  transform: scale(1.02) rotate(-1deg);
}

.dark-mode .flatpaper-tabs__nav-item.is-active {
  color: var(--color-accent-muted);
}

.flatpaper-tabs__panels {
  padding: 16px 18px;
}

.flatpaper-tabs__panel > :first-child { margin-top: 0; }
.flatpaper-tabs__panel > :last-child { margin-bottom: 0; }
.flatpaper-tabs__panel[hidden] { display: none; }


/* ============== FRIENDS / LINK PAGE ============== */
.friends-page {
  padding-bottom: 32px;
}

.friends-subtitle {
  margin: 8px 0 0;
  color: var(--muted);
  font-size: 13px;
}

.friends-page .friends-intro {
  margin-top: 32px;
  padding: 32px 0 4px;
  font-size: 14px;
  border-top: 1px dashed var(--line);
}

.friends-page .friends-intro > :first-child { margin-top: 0; }
.friends-intro > :last-child { margin-bottom: 0; }

.friends-group {
  margin-top: 28px;
}

.friends-group__head {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 8px 14px;
  margin-bottom: 16px;
}

.friends-group__head h2 {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  margin: 0;
  font-size: 18px;
  font-weight: 700;
}

.friends-group__desc {
  color: var(--muted);
  font-size: 12px;
}

.friends-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 14px;
  margin: 0;
  padding: 0;
  list-style: none;
}

/* Wider columns when cards have siteshot previews */
.friends-grid--has-shot {
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
}

.friend-card {
  position: relative;
}

/* ===== Latency status tag ===== */
.friend-card__status {
  position: absolute;
  top: 0;
  left: 0;
  z-index: 5;
  padding: 3px 8px;
  border-radius: 12px 0 12px 0;
  font-size: 11px;
  font-weight: 700;
  line-height: 1.4;
  color: #fff;
  pointer-events: none;
  opacity: 1;
  transition: font-size 0.3s ease-out, opacity 0.3s ease-out;
}

.friend-card:hover .friend-card__status {
  font-size: 0;
  opacity: 0;
}

.friend-card__status--green {
  background-color: #005e00;
}

.friend-card__status--light-yellow {
  background-color: #fed101;
  color: #333;
}

.friend-card__status--dark-yellow {
  background-color: #f0b606;
  color: #333;
}

.friend-card__status--red {
  background-color: #b90000;
}

/* ===== RSS button ===== */
.friend-card__rss {
  position: absolute;
  top: 12px;
  right: 12px;
  z-index: 4;
  display: inline-grid;
  place-items: center;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  color: var(--color-accent-muted);
  background: transparent;
  transition: color 0.25s ease, background 0.25s ease, transform 0.25s ease;
}

.friend-card__rss svg {
  width: 14px;
  height: 14px;
}

.friend-card__rss::before {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 1.5px solid currentColor;
  opacity: 0;
  pointer-events: none;
}

.friend-card:hover .friend-card__rss {
  color: var(--color-accent-strong);
  background: var(--color-accent-soft);
}

.friend-card:hover .friend-card__rss .lucide {
  animation: flatpaper-rss-wiggle 0.7s ease;
}

.friend-card:hover .friend-card__rss::before {
  animation: flatpaper-rss-pulse 1.1s ease-out;
}

.friend-card__rss:hover {
  transform: scale(1.1);
}

@keyframes flatpaper-rss-wiggle {
  0%   { transform: rotate(0)    scale(1); }
  25%  { transform: rotate(-8deg) scale(1.08); }
  50%  { transform: rotate(6deg)  scale(1.12); }
  75%  { transform: rotate(-3deg) scale(1.06); }
  100% { transform: rotate(0)    scale(1); }
}

@keyframes flatpaper-rss-pulse {
  0%   { opacity: 0.45; transform: scale(1); }
  100% { opacity: 0;    transform: scale(1.9); }
}

.dark-mode .friend-card:hover .friend-card__rss {
  color: var(--color-accent-muted);
  background: var(--color-accent-soft);
}

/* ============================================================
   DEFAULT CARD — horizontal (no siteshot)
   ============================================================ */
.friend-card__link {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px;
  border: 1px dashed var(--dash);
  border-radius: 12px;
  background: var(--paper);
  color: var(--ink);
  text-decoration: none;
  transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
}

.friend-card__link:hover {
  transform: translateY(-3px);
  border-color: var(--color-accent);
  box-shadow: var(--small-shadow);
}

.friend-card__avatar-wrap {
  flex-shrink: 0;
  display: inline-grid;
  place-items: center;
  width: 58px;
  height: 58px;
  margin-top: 2px;
  border: 1px solid unquote('rgba(var(--paper-shadow-rgb), 0.12)');
  border-radius: 8px;
  background: var(--paper-solid);
  box-shadow: 2px 3px 0 unquote('rgba(var(--paper-shadow-rgb), 0.08)');
  transform: rotate(-2deg);
  transition: transform 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease;
}

.friend-card__link:hover .friend-card__avatar-wrap {
  border-color: var(--color-accent);
  box-shadow: 3px 5px 0 unquote('rgba(var(--paper-shadow-rgb), 0.1)');
  transform: rotate(0deg) translateY(-1px);
}

.friend-card__avatar {
  display: inline-grid;
  place-items: center;
  width: 50px;
  height: 50px;
  border-radius: 6px;
  object-fit: cover;
  background: var(--color-accent-soft);
  color: var(--color-accent-strong);
  font-size: 18px;
  font-weight: 800;
}

img.friend-card__avatar {
  background: transparent;
}

.dark-mode .friend-card__avatar-wrap {
  border-color: rgba(225, 230, 245, 0.12);
  background: var(--paper-warm);
  box-shadow: 2px 3px 0 rgba(0, 0, 0, 0.18);
}

.dark-mode .friend-card__link:hover .friend-card__avatar-wrap {
  border-color: var(--color-accent-muted);
  box-shadow: 3px 5px 0 rgba(0, 0, 0, 0.22);
}

.dark-mode .friend-card__avatar--text {
  color: var(--color-accent-muted);
}

.friend-card__body {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.friend-card__name {
  font-size: 14px;
  font-weight: 700;
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.friend-card__link:hover .friend-card__name {
  color: var(--color-accent-strong);
}

.dark-mode .friend-card__link:hover .friend-card__name {
  color: var(--color-accent-muted);
}

.friend-card__desc {
  color: var(--muted);
  font-size: 12px;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ============================================================
   SITESHOT CARD — vertical layout (screenshot + avatar overlap)
   ============================================================ */
.friend-card--shot .friend-card__link {
  flex-direction: column;
  align-items: stretch;
  padding: 0;
  border-radius: 12px;
  overflow: hidden;
}

.friend-card__shot-wrap {
  position: relative;
  width: 100%;
  height: 180px;
  overflow: hidden;
  background: var(--paper-warm);
}

.friend-card__shot {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: top center;
  display: block;
  transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.friend-card--shot:hover .friend-card__shot {
  transform: scale(1.05);
}

.dark-mode .friend-card__shot-wrap {
  background: var(--paper-solid);
}

/* Avatar overlapping the shot boundary */
.friend-card--shot .friend-card__avatar-wrap {
  position: relative;
  z-index: 2;
  width: 62px;
  height: 62px;
  margin: -31px 0 0 14px;
  border: 3px solid var(--paper-solid);
  border-radius: 10px;
  box-shadow: 2px 4px 0 unquote('rgba(var(--paper-shadow-rgb), 0.1)');
  transform: rotate(-2deg);
  transition: transform 0.25s ease, box-shadow 0.25s ease;
}

.friend-card--shot:hover .friend-card__avatar-wrap {
  box-shadow: 3px 6px 0 unquote('rgba(var(--paper-shadow-rgb), 0.14)');
  transform: rotate(0deg) translateY(-2px);
}

.friend-card--shot .friend-card__avatar {
  width: 56px;
  height: 56px;
  border-radius: 7px;
}

/* Info area below avatar */
.friend-card--shot .friend-card__body {
  padding: 6px 14px 14px;
}

.friend-card--shot .friend-card__name {
  font-size: 15px;
}

/* Tape decoration on the avatar — mimics a piece of tape holding the photo */
.friend-card--shot .friend-card__avatar-wrap::before {
  content: "";
  position: absolute;
  top: -7px;
  left: 50%;
  transform: translateX(-50%) rotate(-2deg);
  z-index: 1;
  width: 36px;
  height: 12px;
  background-color: var(--feed-tape, var(--tape-yellow));
  background-image: var(--tape-stripes);
  border-radius: 2px;
  box-shadow: 0 2px 6px unquote('rgba(var(--paper-shadow-rgb), 0.1)');
  filter: saturate(0.9);
  pointer-events: none;
}

/* RSS stays bottom-right on siteshot cards */
.friend-card--shot .friend-card__rss {
  top: auto;
  bottom: 12px;
  right: 12px;
}

.dark-mode .friend-card--shot .friend-card__avatar-wrap {
  border-color: var(--paper);
  box-shadow: 2px 4px 0 rgba(0, 0, 0, 0.22);
}

.dark-mode .friend-card--shot:hover .friend-card__avatar-wrap {
  box-shadow: 3px 6px 0 rgba(0, 0, 0, 0.28);
}

/* ============================================================
   EMPTY STATE
   ============================================================ */
.friends-empty {
  margin: 24px 0 8px;
  text-align: center;
  color: var(--muted);
  font-size: 13px;
}

/* ============================================================
   TAPE STYLE — only applies to non-siteshot cards
   ============================================================ */
.friend-card--tape:not(.friend-card--shot) {
  z-index: 1;
  --feed-tilt: -0.3deg;
  --feed-tape: var(--tape-yellow);
  --feed-tab: var(--tape-yellow);
}

.friend-card--tape:not(.friend-card--shot):nth-child(4n+2) {
  --feed-tilt: 0.25deg;
  --feed-tape: var(--tape-green);
  --feed-tab: var(--tape-green);
}

.friend-card--tape:not(.friend-card--shot):nth-child(4n+3) {
  --feed-tilt: -0.15deg;
  --feed-tape: var(--tape-blue);
  --feed-tab: var(--tape-blue);
}

.friend-card--tape:not(.friend-card--shot):nth-child(4n+4) {
  --feed-tilt: 0.35deg;
  --feed-tape: var(--tape-pink);
  --feed-tab: var(--tape-pink);
}

.friend-card--tape:not(.friend-card--shot):hover {
  z-index: 10;
}

.friend-card--tape:not(.friend-card--shot) .friend-card__link {
  position: relative;
  border: 1px dashed var(--dash);
  border-radius: 10px;
  background:
    linear-gradient(var(--paper) 0 27px, rgba(221, 208, 181, 0.15) 27px 28px),
    var(--paper);
  background-size: 100% 28px;
  box-shadow: 3px 4px 0 unquote('rgba(var(--paper-shadow-rgb), 0.06)'), var(--soft-shadow);
  isolation: isolate;
  transform: rotate(var(--feed-tilt));
  transition: transform 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease;
}

.friend-card--tape:not(.friend-card--shot) .friend-card__link:hover {
  transform: translateY(-3px) rotate(0deg);
  border-color: var(--color-accent);
  box-shadow: 5px 7px 0 unquote('rgba(var(--paper-shadow-rgb), 0.08)'), var(--small-shadow);
}

.dark-mode .friend-card--tape:not(.friend-card--shot) .friend-card__link {
  background:
    linear-gradient(var(--paper) 0 27px, rgba(225, 230, 245, 0.05) 27px 28px),
    var(--paper);
  background-size: 100% 28px;
  box-shadow: 3px 4px 0 rgba(0, 0, 0, 0.15), var(--soft-shadow);
}

.dark-mode .friend-card--tape:not(.friend-card--shot) .friend-card__link:hover {
  box-shadow: 5px 7px 0 rgba(0, 0, 0, 0.22), var(--small-shadow);
}

/* Tape strip — centered on top */
.friend-card--tape:not(.friend-card--shot) .friend-card__link::before {
  content: "";
  position: absolute;
  top: -7px;
  left: 50%;
  transform: translateX(-50%) rotate(-2deg);
  z-index: 2;
  width: 40px;
  height: 14px;
  background-color: var(--feed-tape);
  background-image: var(--tape-stripes);
  border-radius: 2px;
  box-shadow: 0 2px 6px unquote('rgba(var(--paper-shadow-rgb), 0.1)');
  filter: saturate(0.9);
  pointer-events: none;
}

/* Tab on right edge — matching tape color */
.friend-card--tape:not(.friend-card--shot) .friend-card__link::after {
  content: "";
  position: absolute;
  top: 50%;
  right: -5px;
  transform: translateY(-50%);
  z-index: -1;
  width: 5px;
  height: 36px;
  border-radius: 0 4px 4px 0;
  background: var(--feed-tab);
  box-shadow: 2px 2px 0 unquote('rgba(var(--paper-shadow-rgb), 0.06)');
  transition: width 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), right 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  pointer-events: none;
}

.friend-card--tape:not(.friend-card--shot) .friend-card__link:hover::after {
  right: -10px;
  width: 10px;
}

.dark-mode .friend-card--tape:not(.friend-card--shot) .friend-card__link::before {
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.22);
}

.dark-mode .friend-card--tape:not(.friend-card--shot) .friend-card__link::after {
  box-shadow: 2px 2px 0 rgba(0, 0, 0, 0.12);
}

.tape-disabled .friend-card--tape .friend-card__link::before,
.tape-disabled .friend-card--tape .friend-card__link::after {
  display: none;
}

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media (max-width: 640px) {
  .friends-grid--has-shot {
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  }

  .friend-card--shot .friend-card__shot-wrap {
    height: 150px;
  }
}

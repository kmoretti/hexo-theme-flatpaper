/* ============== WELCOME CARD ============== */
.welcome-card {
  padding: 18px;
}

.welcome-thumb {
  position: relative;
  height: 110px;
  margin-bottom: 18px;
  border-radius: 4px;
  overflow: hidden;
  background: linear-gradient(180deg, #d5e7d4 0%, #ecf3d8 100%);
  filter: url(#paper-edge);
}

.welcome-thumb--image {
  height: auto;
  aspect-ratio: 16 / 9;
  background: var(--paper-warm);
  margin: -18px -18px 18px;
  border-radius: 4px 4px 0 0;
  filter: url(#paper-edge);
}

.welcome-thumb--image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.welcome-thumb .sun {
  top: 16px;
  left: 26%;
  width: 28px;
  height: 28px;
}

.welcome-thumb .mountain {
  bottom: -2px;
}

.welcome-thumb .mountain-a {
  left: -8%;
  width: 70%;
  height: 70%;
}

.welcome-thumb .mountain-b {
  right: -6%;
  width: 60%;
  height: 55%;
}

.welcome-thumb .cloud {
  transform: scale(0.55);
}

.welcome-thumb .cloud-a {
  right: 12%;
  top: 14px;
}

.welcome-thumb .cloud-b {
  left: 8%;
  top: 36px;
}

.welcome-card .hello {
  display: flex;
  align-items: center;
  gap: 8px;
  margin: 0 0 8px;
  padding: 0 4px;
  color: var(--color-accent-strong);
  font-weight: 700;
  font-size: 13px;
}

.welcome-card h1 {
  position: relative;
  display: inline;
  margin: 0;
  padding: 0 4px;
  font-size: 20px;
  font-weight: 800;
  line-height: 1.5;
  letter-spacing: 0;
}

.welcome-card h1::after {
  content: "";
  position: absolute;
  left: 4px;
  right: 4px;
  bottom: 1px;
  z-index: -1;
  height: 8px;
  background: rgba(241, 193, 84, 0.4);
}

.welcome-card .welcome-text {
  margin: 12px 4px 16px;
  color: var(--muted);
  font-size: 13px;
  line-height: 1.7;
}

/* Shared styling with .pager-link — same dashed pill, fills green on hover. */
.welcome-cta,
.read-more {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: fit-content;
  margin: 0 4px 0 auto;
  padding: 8px 18px;
  color: var(--ink-soft);
  font-size: 13px;
  font-weight: 600;
  transition: color 0.2s ease, transform 0.2s ease;
  z-index: 1;
}

.welcome-cta::before,
.read-more::before {
  content: "";
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: var(--paper-warm);
  z-index: -1;
  border-radius: 4px;
  filter: url(#paper-edge) drop-shadow(var(--paper-shadow));
  transition: background 0.2s ease, box-shadow 0.2s ease;
}

.welcome-cta:hover,
.read-more:hover {
  color: var(--color-accent-strong);
  transform: translateY(-1px);
}

.welcome-cta:hover::before,
.read-more:hover::before {
  background: var(--color-accent-soft);
  box-shadow: inset 0 0 0 1px var(--color-accent);
}

.welcome-cta .lucide,
.read-more .lucide {
  width: 14px;
  height: 14px;
  transition: transform 0.2s ease;
}

.welcome-cta:hover .lucide,
.read-more:hover .lucide {
  transform: translateX(2px);
}

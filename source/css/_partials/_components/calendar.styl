/* ============ Calendar Card ============ */

.calendar-card__body {
  font-family: var(--font-body);
}

.calendar-card__row {
  display: flex;
  gap: 12px;
  margin-bottom: 12px;
}

.calendar-card__left {
  width: 45%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.calendar-card__date {
  font-size: 64px;
  font-weight: 900;
  line-height: 1.1;
  color: var(--accent);
  font-family: var(--font-mono);
  letter-spacing: 2px;
}

.calendar-card__week {
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 1px;
  color: var(--ink);
  margin-top: 4px;
}

.calendar-card__right {
  width: 55%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
}

.calendar-card__meta {
  font-size: 12px;
  line-height: 1.5;
  color: var(--muted);
}

.calendar-card__lunar {
  color: var(--ink-soft);
  font-size: 13px;
  font-weight: 600;
  display: block;
  margin-top: 2px;
}

/* ---- Grid ---- */
.calendar-card__grid {
  width: 100%;
}

.calendar-rh,
.calendar-r0,
.calendar-r1,
.calendar-r2,
.calendar-r3,
.calendar-r4,
.calendar-r5 {
  display: flex;
  height: 1.3rem;
  align-items: center;
}

.calendar-rh {
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 1px;
  color: var(--ink-soft);
  margin-bottom: 2px;
}

.calendar-rh .calendar-d0,
.calendar-rh .calendar-d6 {
  color: var(--accent);
}

.calendar-d0,
.calendar-d1,
.calendar-d2,
.calendar-d3,
.calendar-d4,
.calendar-d5,
.calendar-d6 {
  width: calc(100% / 7);
  display: flex;
  justify-content: center;
  align-items: center;
}

.calendar-card__grid a {
  display: inline-flex;
  width: 1.2rem;
  height: 1.2rem;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 12px;
  line-height: 1;
  text-decoration: none;
  color: var(--ink);
  transition: background 0.2s ease, color 0.2s ease;
}

.calendar-card__grid a.now {
  background: var(--accent);
  color: var(--paper);
  font-weight: 700;
}

.calendar-card__grid .calendar-r0 a {
  color: var(--muted);
}

/* ---- Dark mode ---- */
.dark-mode .calendar-card__grid a.now {
  color: var(--ink);
}

/* ============ Schedule Card ============ */

.schedule-card__body {
  font-family: var(--font-body);
}

.schedule-card__row {
  display: flex;
  gap: 12px;
}

.schedule-card__left {
  width: 30%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.schedule-card__right {
  width: 70%;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.schedule-card__countdown-title {
  font-size: 13px;
  font-weight: 700;
  color: var(--ink);
}

.schedule-card__countdown {
  font-size: 30px;
  font-weight: 900;
  line-height: 1.2;
  color: var(--accent);
  font-family: var(--font-mono);
}

.schedule-card__countdown-date {
  font-size: 11px;
  color: var(--muted);
}

.schedule-r0,
.schedule-r1,
.schedule-r2 {
  display: flex;
  align-items: center;
  height: 2rem;
  width: 100%;
}

.schedule-d0 {
  width: 30px;
  margin-right: 5px;
  text-align: center;
  font-size: 12px;
  color: var(--ink-soft);
  flex-shrink: 0;
}

.schedule-d1 {
  width: calc(100% - 35px);
  height: 1.5rem;
  display: flex;
  align-items: center;
  position: relative;
}

.schedule-d1 progress {
  width: 100%;
  height: 100%;
  border-radius: 5px;
  overflow: hidden;
  -webkit-appearance: none;
  appearance: none;
}

.schedule-d1 progress::-webkit-progress-bar {
  background: linear-gradient(to right, var(--color-accent-soft), var(--paper-warm));
  border-radius: 5px;
  overflow: hidden;
}

.schedule-d1 progress::-webkit-progress-value {
  background: var(--accent);
  border-radius: 5px;
}

.schedule-d1 progress::-moz-progress-bar {
  background: var(--accent);
  border-radius: 5px;
}

.aside-span1 {
  position: absolute;
  left: 5px;
  font-size: 12px;
  z-index: 1;
  color: var(--paper);
  font-weight: 700;
  text-shadow: 0 1px 1px rgba(0, 0, 0, 0.25);
  pointer-events: none;
}

.aside-span2 {
  position: absolute;
  right: 8px;
  font-size: 11px;
  z-index: 1;
  color: var(--muted);
  pointer-events: none;
}

.aside-span2 span {
  color: var(--accent);
  font-weight: 700;
}

/* ============ Responsive ============ */
@media (max-width: 960px) {
  .calendar-card__date {
    font-size: 48px;
  }

  .schedule-card__countdown {
    font-size: 24px;
  }
}

/* ============ Reduced motion ============ */
@media (prefers-reduced-motion: reduce) {
  .calendar-card__grid a {
    transition: none;
  }
}
